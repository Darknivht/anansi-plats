# ══════════════════════════════════════════════════════════════
# ANANSI — Environment Variables
# All variables with placeholders. Copy to .env and fill in.
# ══════════════════════════════════════════════════════════════

# ─── Core ───
DATABASE_URL="postgresql+asyncpg://user:pass@host:5432/anansi"
DATABASE_URL_SYNC="postgresql://user:pass@host:5432/anansi"
NEO4J_URI="bolt://host:7687"
NEO4J_USER="neo4j"
NEO4J_PASSWORD="your-neo4j-password"
REDIS_URL="redis://host:6379/0"
SECRET_KEY="generate-a-256-bit-random-secret"
NEXT_PUBLIC_APP_URL="https://anansi.ai"
NEXT_PUBLIC_API_URL="https://api.anansi.ai"
NEXT_PUBLIC_WS_URL="wss://api.anansi.ai"

# ─── Auth (JWT + OAuth) ───
JWT_SECRET="your-jwt-signing-secret-rs256"
JWT_ACCESS_EXPIRY=900
JWT_REFRESH_EXPIRY=604800
GOOGLE_CLIENT_ID="your-google-oauth-client-id"
GOOGLE_CLIENT_SECRET="your-google-oauth-client-secret"
GITHUB_CLIENT_ID="your-github-oauth-client-id"
GITHUB_CLIENT_SECRET="your-github-oauth-client-secret"

# ─── AI / LLM Providers ───
OPENAI_API_KEY="sk-proj-your-openai-api-key"
ANTHROPIC_API_KEY="sk-ant-your-anthropic-api-key"
GROQ_API_KEY="gsk-your-groq-api-key"
OLLAMA_BASE_URL="http://localhost:11434"

# ─── WhatsApp Business API ───
WHATSAPP_API_TOKEN="your-whatsapp-cloud-api-token"
WHATSAPP_PHONE_NUMBER_ID="your-whatsapp-phone-number-id"
WHATSAPP_WEBHOOK_VERIFY_TOKEN="your-webhook-verify-token"

# ─── Payments ───
STRIPE_SECRET_KEY="sk_live_your-stripe-secret-key"
STRIPE_WEBHOOK_SECRET="whsec_your-stripe-webhook-secret"
PAYSTACK_SECRET_KEY="sk_live_your-paystack-secret-key"

# ─── Storage (S3-compatible — Cloudflare R2 / AWS S3 / MinIO) ───
S3_ENDPOINT="https://your-account.r2.cloudflarestorage.com"
S3_ACCESS_KEY="your-s3-access-key-id"
S3_SECRET_KEY="your-s3-secret-access-key"
S3_BUCKET="anansi-media"
S3_REGION="auto"

# ─── Search ───
MEILISEARCH_URL="http://localhost:7700"
MEILISEARCH_MASTER_KEY="your-meilisearch-master-key"

# ─── Monitoring & Observability ───
SENTRY_DSN="https://your-dsn@your-project.ingest.us.sentry.io/project-id"
SENTRY_ENVIRONMENT="production"
OTEL_EXPORTER_OTLP_ENDPOINT="https://api.honeycomb.io:443"
OTEL_EXPORTER_OTLP_HEADERS="x-honeycomb-team=your-honeycomb-api-key"
OTEL_SERVICE_NAME="anansi"

# ─── Email (Resend) ───
RESEND_API_KEY="re_your-resend-api-key"
EMAIL_FROM="Anansi <noreply@anansi.ai>"
EMAIL_FROM_NAME="Anansi"

# ─── Twilio (WhatsApp SMS fallback) ───
TWILIO_ACCOUNT_SID="your-twilio-account-sid"
TWILIO_AUTH_TOKEN="your-twilio-auth-token"
TWILIO_WHATSAPP_NUMBER="+14155238886"
