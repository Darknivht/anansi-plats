# ══════════════════════════════════════════════════
# ANANSI Frontend — Environment Variables
# Prefix with NEXT_PUBLIC_ for client-side access
# ══════════════════════════════════════════════════

# ─── API URLs ───
NEXT_PUBLIC_API_URL="http://localhost:8000"
NEXT_PUBLIC_WS_URL="ws://localhost:8000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ─── Auth ───
NEXT_PUBLIC_GOOGLE_CLIENT_ID=""
NEXT_PUBLIC_GITHUB_CLIENT_ID=""
NEXT_PUBLIC_ENABLE_OAUTH=true

# ─── Features ───
NEXT_PUBLIC_ENABLE_WHATSAPP=true
NEXT_PUBLIC_ENABLE_MARKETPLACE=true
NEXT_PUBLIC_ENABLE_BRAIN_EXPORT=true
NEXT_PUBLIC_ENABLE_GRAPH_VIEW_3D=false

# ─── Monitoring ───
NEXT_PUBLIC_SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_ENVIRONMENT="development"

# ─── Analytics (Privacy-first, self-hosted) ───
NEXT_PUBLIC_UMAMI_WEBSITE_ID=""
NEXT_PUBLIC_UMAMI_URL=""

# ─── App Config ───
NEXT_PUBLIC_DEFAULT_THEME="dark"
NEXT_PUBLIC_DEFAULT_TIMEZONE="Africa/Lagos"
NEXT_PUBLIC_DEFAULT_LANGUAGE="en"
NEXT_PUBLIC_SITE_NAME="Anansi"
NEXT_PUBLIC_SITE_DESCRIPTION="Your AI. Your Life. Your OS."
