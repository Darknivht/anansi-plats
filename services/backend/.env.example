# ══════════════════════════════════════════════════
# ANANSI Backend — Environment Variables
# ══════════════════════════════════════════════════

# ─── Core ───
DATABASE_URL="postgresql+asyncpg://anansi:your-password@localhost:5432/anansi"
DATABASE_URL_SYNC="postgresql://anansi:your-password@localhost:5432/anansi"
NEO4J_URI="bolt://localhost:7687"
NEO4J_USER="neo4j"
NEO4J_PASSWORD="your-neo4j-password"
REDIS_URL="redis://localhost:6379/0"
SECRET_KEY="your-256-bit-secret-key"
DEBUG=true
LOG_LEVEL="debug"

# ─── Server ───
HOST="0.0.0.0"
PORT=8000
WORKERS=4
CORS_ORIGINS="http://localhost:3000,http://localhost:8000"
ALLOWED_HOSTS="localhost,api.anansi.local"

# ─── Auth ───
JWT_SECRET="your-jwt-secret"
JWT_ALGORITHM="RS256"
JWT_ACCESS_EXPIRY=900
JWT_REFRESH_EXPIRY=604800
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# ─── AI ───
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
GROQ_API_KEY=""
OLLAMA_BASE_URL="http://localhost:11434"
DEFAULT_AI_MODEL="claude-sonnet-4-20250514"
AI_MAX_TOKENS=4096
AI_TEMPERATURE=0.7

# ─── WhatsApp ───
WHATSAPP_API_TOKEN=""
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_WEBHOOK_VERIFY_TOKEN=""

# ─── Payments ───
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
PAYSTACK_SECRET_KEY=""

# ─── Storage ───
S3_ENDPOINT="http://localhost:9000"
S3_ACCESS_KEY="minioadmin"
S3_SECRET_KEY="minioadmin"
S3_BUCKET="anansi-media"
S3_REGION="auto"

# ─── Search ───
MEILISEARCH_URL="http://localhost:7700"
MEILISEARCH_MASTER_KEY=""

# ─── Monitoring ───
SENTRY_DSN=""
SENTRY_ENVIRONMENT="development"
OTEL_EXPORTER_OTLP_ENDPOINT=""
OTEL_SERVICE_NAME="anansi-api"

# ─── Email ───
RESEND_API_KEY=""
EMAIL_FROM="noreply@anansi.ai"

# ─── Twilio ───
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_WHATSAPP_NUMBER="+14155238886"

# ─── Rate Limiting ───
RATE_LIMIT_ENABLED=true
RATE_LIMIT_STANDARD="100/minute"
RATE_LIMIT_BUSINESS="1000/minute"
