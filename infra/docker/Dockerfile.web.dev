# ──────────────────────────────────────────────
# Anansi Web — Development Dockerfile
# Next.js 16 + Hot Reload (Turbopack)
# ──────────────────────────────────────────────

FROM node:22-alpine

WORKDIR /app

RUN apk add --no-cache libc6-compat

# Copy workspace config files first (for layer caching)
COPY package.json package-lock.json* ./
COPY services/frontend/package.json services/frontend/package-lock.json* ./services/frontend/

RUN npm ci

EXPOSE 3000

ENV NEXT_TELEMETRY_DISABLED=1
ENV WATCHPACK_POLLING=true

# Code is mounted as a volume in docker-compose
CMD ["npm", "run", "dev", "-w", "@anansi/web"]
