# ══════════════════════════════════════════════════
# ANANSI — .gitignore
# ══════════════════════════════════════════════════

# ─── Node / NPM ───
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
pnpm-lock.yaml
.yarn/
.yarnrc.yml

# ─── Next.js ───
.next/
.next_*
out/
build/

# ─── Python ───
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
*.egg
dist/
build/
develop-eggs/
downloads/
eggs/
lib/
!services/frontend/src/lib/
lib64/
parts/
sdist/
var/
wheels/
*.whl
*.so
.python-version
pip-wheel-metadata/
share/python-wheels/
*.manifest
*.spec
*.pyc
*.pyo

# ─── Virtual Environments ───
.venv/
venv/
env/
ENV/
env.bak/
venv.bak/

# ─── Docker ───
docker-compose.override.yml

# ─── IDE ───
.idea/
*.iml
.vscode/
*.swp
*.swo
*~
.DS_Store
.vscode/settings.json
.idea/workspace.xml

# ─── Env Files ───
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.env.local
*.env.development*
*.env.test*
*.env.production*

# ─── Secrets ───
*.pem
*.key
*.cert
secrets/
service-account*.json
credentials*.json

# ─── Testing ───
coverage/
.coverage
coverage.xml
*.coverage
htmlcov/
.pytest_cache/
.vitest/
test-results/
playwright-report/

# ─── Logs ───
logs/
*.log
*.out
*.pid

# ─── Database ───
*.db
*.sqlite
*.sqlite3

# ─── Uploads & Temp ───
tmp/
temp/
uploads/
media/
staticfiles/
*.tmp
*.temp

# ─── OS ───
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini
$RECYCLE.BIN/

# ─── Monitoring ───
otel-*

# ─── Migrations (auto-generated might contain env-specific data) ───
# Keep version-controlled migrations, ignore auto-generated ones
# services/backend/migrations/versions/

# ─── TypeScript / Build ───
*.tsbuildinfo
next-env.d.ts

# ─── Certificates & SSL ───
*.crt
*.csr

# ─── Railway ───
.railway/

# ─── GitHub Actions ───
!.github/
